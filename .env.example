# Konfiguracja środowiska — Siedlisko Konradówka
# Skopiuj ten plik jako .env i uzupełnij prawdziwe wartości.
# Plik .env NIE może trafić do repozytorium (jest w .gitignore).

# ======= NODEMAILER (fallback dla /api/reservation) =======
# Wymagane tylko jeżeli korzystasz z backendowej wysyłki maili.
# Frontend domyślnie używa EmailJS (patrz client/scripts/email.js).

EMAIL_USER=siedliskokonradowka@gmail.com
EMAIL_PASS=xxxxxxxxxxxxxxxx

# Adres, na który mają trafiać rezerwacje (zazwyczaj ten sam co EMAIL_USER)
ADMIN_EMAIL=siedliskokonradowka@gmail.com

# ======= SERWER =======
PORT=3000

# ======= UWAGA O HAŚLE GMAIL =======
# Gmail wymaga "hasła aplikacji" zamiast zwykłego hasła:
# 1) Włącz weryfikację dwuetapową: https://myaccount.google.com/security
# 2) Wygeneruj hasło aplikacji: https://myaccount.google.com/apppasswords
# 3) Skopiuj 16-znakowe hasło do EMAIL_PASS (bez spacji)
